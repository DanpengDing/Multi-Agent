# Docker 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ========== AI 服务（至少配置一个）==========

# 硅基流动
SF_API_KEY=your_sf_api_key_here
SF_BASE_URL=https://api.siliconflow.cn/v1

# 阿里百炼
AL_BAILIAN_API_KEY=your_bailian_api_key_here
AL_BAILIAN_BASE_URL=https://dashscope.aliyuncs.com

# ========== 数据库配置 ==========

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=multi_agent_db
